# Copy this file to .env.local for local-only overrides (the .gitignore
# excludes .env.local but tracks .env.example so the schema is shared).
#
# All client-exposed variables MUST be prefixed with VITE_ — Vite only
# exposes that subset to the bundle.

# ── Firebase environment switch ─────────────────────────────────────────
# Default = unset = prod. Set to "staging" to point the client at the
# alen-staging Firebase project. Also wire firebase CLI with:
#   firebase use staging
# See docs/staging-setup.md for the one-time setup.
# VITE_FIREBASE_ENV=staging

# ── Error tracking (Sentry) ─────────────────────────────────────────────
# When set, errors caught by AppErrorBoundary and any reportError() call
# get sent to Sentry. When unset, Sentry's SDK is never even loaded
# (lazy-imported at runtime). Sign up at https://sentry.io to get a DSN.
# VITE_SENTRY_DSN=https://YOUR_PUBLIC_KEY@oXXXX.ingest.sentry.io/PROJECT_ID
